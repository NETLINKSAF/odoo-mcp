{
  "name": "odoo-mcp-monorepo",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm biome check .",
    "format": "pnpm biome check --write .",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test:integration": "pnpm --filter @netlinksinc/odoo-mcp test:integration",
    "audit": "pnpm audit --prod && pnpm -r exec pnpm audit --prod"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "typescript": "^5.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
