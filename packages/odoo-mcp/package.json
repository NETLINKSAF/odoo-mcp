{
  "name": "@netlinksinc/odoo-mcp",
  "version": "0.2.0",
  "description": "MCP server exposing any Odoo 19 instance to Claude (Desktop, Code, Cowork) \u2014 generic-only tool surface, works on stock and customized Odoo",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "odoo",
    "odoo19",
    "erp",
    "ai",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NETLINKSAF/odoo-mcp.git",
    "directory": "packages/odoo-mcp"
  },
  "homepage": "https://github.com/NETLINKSAF/odoo-mcp#readme",
  "bugs": "https://github.com/NETLINKSAF/odoo-mcp/issues",
  "author": "NETLINKS Inc",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "odoo-mcp": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@netlinksinc/odoo-client": "workspace:*",
    "@modelcontextprotocol/sdk": "^1",
    "zod": "^3"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
